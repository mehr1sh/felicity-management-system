PORT=4000
MONGODB_URI=mongodb://127.0.0.1:27017/felicity
JWT_SECRET=change-me
JWT_EXPIRES_IN=7d

# Admin bootstrap (created automatically on server start if not present)
ADMIN_EMAIL=admin@felicity.local
ADMIN_PASSWORD=ChangeThisAdminPassword123!

# Participant constraints (comma-separated list of allowed IIIT email domains)
IIIT_EMAIL_DOMAINS=iiit.ac.in,students.iiit.ac.in,research.iiit.ac.in

# Email (optional; if unset, emails are logged to console)
SMTP_HOST=
SMTP_PORT=
SMTP_USER=
SMTP_PASS=
SMTP_FROM="Felicity EMS <no-reply@felicity.local>"
